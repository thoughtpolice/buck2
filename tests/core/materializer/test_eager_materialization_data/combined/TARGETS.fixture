load(":defs.bzl", "consumer_combined", "consumer_content", "content_based", "make_dir", "node", "regular")

regular(name = "regular")

make_dir(name = "make_dir")

node(name = "leaf_a")

node(name = "leaf_b")

node(name = "node_x", deps = [":leaf_a", ":leaf_b"])

consumer_combined(
    name = "consumer",
    projected_dep = ":make_dir[file_a]",
    regular_dep = ":regular",
    tset_dep = ":node_x",
)

content_based(name = "content")

consumer_content(
    name = "consumer_content",
    content_dep = ":content",
)
