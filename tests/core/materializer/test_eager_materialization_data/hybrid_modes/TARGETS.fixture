load("@root//:rules.bzl", "consumer", "producer")

producer(name = "input")

consumer(
    name = "consumer_prefer_local",
    dep = ":input",
    default_target_platform = "//platforms:target",
    prefer_local = True,
)

consumer(
    name = "consumer_default",
    dep = ":input",
    default_target_platform = "//platforms:target",
)
