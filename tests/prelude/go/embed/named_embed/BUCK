load("@fbcode//buck2/tests/prelude:py_assertion.bzl", "py_assertion")

oncall("golang")

prelude = native

# Generate a file - the output name differs from what Go code will embed
prelude.write_file(
    name = "generate_config",
    out = "generated_config_v1.json",
    content = ['{"message": "HELLO FROM CONFIG"}'],
)

# Use dict format to give it a stable name for embedding
prelude.go_binary(
    name = "bin",
    srcs = ["main.go"],
    embed_srcs = {
        # The Go code embeds "config.json", but the actual file comes from
        # a write_file with a different output name
        "config.json": ":generate_config",
    },
)

prelude.go_test(
    name = "test",
    srcs = [
        "main.go",
        "main_test.go",
    ],
    embed_srcs = {
        "config.json": ":generate_config",
    },
    # @oss-disable[end= ]: env = {"GO_TEST2JSON_TOOL": "$(exe_target fbsource//third-party/go:test2json)"},
)

py_assertion(
    name = "check_output",
    script = """
import subprocess
import sys
assert "HELLO FROM CONFIG" in subprocess.check_output([sys.argv[1]]).decode()
""",
    script_args = ["$(exe_target :bin)"],
)
